{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install --prefer-offline --no-audit --fund=false --progress=false",
  "buildCommand": "npm run build",
  "ignoreCommand": "node scripts/vercel-ignore-build.mjs",
  "git": {
    "deploymentEnabled": {
      "*": false,
      "main": true
    }
  }
}
