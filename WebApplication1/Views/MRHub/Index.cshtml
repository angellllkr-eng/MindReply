@{
    ViewData["Title"] = "MRhub — Plans & Pricing";
    var plans = ViewBag.Plans as List<WebApplication1.Models.PricingPlan> ?? new();
}

<section class="mr-hero">
    <div class="mr-hero__inner">
        <span class="mr-eyebrow">Plans · Packs · Memberships</span>
        <h1 class="mr-hero__title">Invest in clarity.</h1>
        <p class="mr-hero__sub">One plan for every stage. Cancel anytime.</p>
    </div>
</section>

<section class="mrh-pricing container-fluid">
    <div class="mrh-plans">
        @foreach (var plan in plans)
        {
            <div class="mrh-plan @(plan.IsHighlighted ? "mrh-plan--highlight" : "")">
                @if (!string.IsNullOrEmpty(plan.Badge))
                {
                    <div class="mrh-plan__badge">@plan.Badge</div>
                }
                <div class="mrh-plan__name">@plan.Name</div>
                <div class="mrh-plan__price">
                    @if (plan.PriceGbp == 0)
                    {
                        <span class="mrh-plan__amount">Free</span>
                    }
                    else
                    {
                        <span class="mrh-plan__amount">£@plan.PriceGbp</span>
                        <span class="mrh-plan__period">@plan.Period</span>
                    }
                </div>
                <ul class="mrh-plan__features">
                    @foreach (var f in plan.Features)
                    {
                        <li>@f</li>
                    }
                </ul>
                <a href="mailto:angelllkr@gmail.com?subject=MRhub%20-%20@plan.Name%20Plan"
                   class="@(plan.IsHighlighted ? "mr-btn-book" : "mr-btn-ghost") mrh-plan__cta">
                    @plan.CtaText
                </a>
            </div>
        }
    </div>
</section>

<section class="mrh-pack container-fluid">
    <div class="mrh-pack__inner">
        <div class="mrh-pack__text">
            <span class="mr-eyebrow">Limited Offer</span>
            <h2>The MindReply Pack</h2>
            <p>Bundle 5 services — get <strong>30% off</strong> plus <strong>2 bonus days</strong> of async MRagent support.</p>
            <a href="mailto:angelllkr@gmail.com?subject=MindReply%20Pack%20Enquiry" class="mr-btn-book">Claim Pack Deal</a>
        </div>
        <div class="mrh-pack__stats">
            <div class="mrh-pack__stat"><span>30%</span><small>Discount</small></div>
            <div class="mrh-pack__stat"><span>+2</span><small>Bonus Days</small></div>
            <div class="mrh-pack__stat"><span>5</span><small>Services</small></div>
        </div>
    </div>
</section>

<section class="mrh-faq container">
    <h2 class="mrh-faq__title">Common questions</h2>
    <div class="mrh-faq__list">
        <details class="mrh-faq__item">
            <summary>Can I cancel anytime?</summary>
            <p>Yes. Cancel before your next billing cycle with no questions asked.</p>
        </details>
        <details class="mrh-faq__item">
            <summary>Is the 7-day trial really free?</summary>
            <p>Yes. No charge until day 8. You'll receive a reminder on day 6.</p>
        </details>
        <details class="mrh-faq__item">
            <summary>What counts as a group booking discount?</summary>
            <p>Groups of 10 or more automatically receive 10% off per session plus 2 bonus days of async support.</p>
        </details>
        <details class="mrh-faq__item">
            <summary>How does MRagent usage billing work?</summary>
            <p>Free tier: 5 messages/month. Professional: unlimited. Executive: dedicated persona with extended context memory.</p>
        </details>
    </div>
</section>
