@model WebApplication1.Models.BookingViewModel
@{
    ViewData["Title"] = "Book a Session — MindReply";
}

@* ─── Hero ──────────────────────────────────────────────────── *@
<section class="mr-hero">
    <div class="mr-hero__inner">
        <span class="mr-eyebrow">Worldwide · Private · Vetted</span>
        <h1 class="mr-hero__title">Find your specialist.<br>Book in minutes.</h1>
        <p class="mr-hero__sub">Deeply niched professionals. Real results. No waiting lists.</p>
    </div>
</section>

@* ─── Currency Bar ───────────────────────────────────────────── *@
<div class="mr-currency-bar container-fluid">
    <div class="d-flex align-items-center gap-3 flex-wrap">
        <span class="mr-currency-label">Currency</span>
        <div class="mr-currency-tabs" id="currencyTabs">
            <button class="mr-currency-btn active" data-rate="1" data-symbol="£" data-code="GBP">£ GBP</button>
            <button class="mr-currency-btn" data-rate="1.27" data-symbol="$" data-code="USD">$ USD</button>
            <button class="mr-currency-btn" data-rate="1.17" data-symbol="€" data-code="EUR">€ EUR</button>
            <button class="mr-currency-btn" data-rate="191" data-symbol="AED" data-code="AED">AED</button>
            <button class="mr-currency-btn" data-rate="168" data-symbol="¥" data-code="JPY">¥ JPY</button>
            <button class="mr-currency-btn" data-rate="1.95" data-symbol="A$" data-code="AUD">A$ AUD</button>
            <button class="mr-currency-btn" data-rate="1.69" data-symbol="C$" data-code="CAD">C$ CAD</button>
            <button class="mr-currency-btn" data-rate="4.06" data-symbol="R$" data-code="BRL">R$ BRL</button>
        </div>
    </div>
</div>

@* ─── Category Filter ────────────────────────────────────────── *@
<div class="mr-filter-bar container-fluid">
    <div class="mr-filter-scroll" id="categoryFilter">
        @foreach (var cat in Model.Categories)
        {
            <a href="/Booking?category=@Uri.EscapeDataString(cat)"
               class="mr-filter-chip @(Model.SelectedCategory == cat ? "active" : "")">@cat</a>
        }
    </div>
</div>

@* ─── Professionals Grid ─────────────────────────────────────── *@
<section class="mr-grid container-fluid">
    <div class="row g-4" id="profGrid">
        @foreach (var p in Model.Professionals)
        {
            <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                <div class="mr-card">
                    @if (!string.IsNullOrEmpty(p.Badge))
                    {
                        <div class="mr-card__badge mr-badge--@p.Badge.ToLower().Replace(" ", "-")">@p.Badge</div>
                    }
                    <div class="mr-card__photo-wrap">
                        <img src="@p.PhotoUrl"
                             alt="Photo of @p.Name"
                             class="mr-card__photo"
                             loading="lazy"
                             onerror="this.src='https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=400&h=400&fit=crop&crop=face'" />
                        @if (p.IsAvailableToday)
                        {
                            <span class="mr-card__avail">Available today</span>
                        }
                    </div>
                    <div class="mr-card__body">
                        <p class="mr-card__role">@p.Role</p>
                        <h3 class="mr-card__name">@p.Name</h3>
                        <p class="mr-card__niche">@p.Niche</p>
                        <p class="mr-card__bio">@p.ShortBio</p>

                        @* Stars *@
                        <div class="mr-card__stars" aria-label="Rating @p.RatingStars out of 5">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var full = (decimal)i <= Math.Floor(p.RatingStars);
                                var half = !full && (decimal)i <= p.RatingStars + 0.5m && p.RatingStars % 1 >= 0.25m;
                                <span class="mr-star @(full ? "mr-star--full" : half ? "mr-star--half" : "mr-star--empty")">★</span>
                            }
                            <span class="mr-card__review-count">(@p.ReviewCount)</span>
                        </div>

                        @* Languages *@
                        <div class="mr-card__langs">
                            @foreach (var lang in p.Languages)
                            {
                                <span class="mr-lang-tag">@lang</span>
                            }
                        </div>

                        @* Specialties *@
                        <div class="mr-card__tags">
                            @foreach (var spec in p.Specialties.Take(3))
                            {
                                <span class="mr-spec-tag">@spec</span>
                            }
                        </div>

                        @* Price + CTA *@
                        <div class="mr-card__footer">
                            <div class="mr-card__price-block">
                                <span class="mr-card__price"
                                      data-base-gbp="@p.PriceGbp"
                                      data-symbol="£">£@p.PriceGbp</span>
                                <span class="mr-card__session">/ @p.SessionLength</span>
                            </div>
                            <a href="@p.CalendarLink"
                               class="mr-btn-book"
                               target="_blank"
                               rel="noopener noreferrer"
                               aria-label="Book session with @p.Name">
                                Book Now
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@* ─── Empty State ────────────────────────────────────────────── *@
@if (!Model.Professionals.Any())
{
    <div class="mr-empty container text-center py-5">
        <p>No specialists found in this category yet.</p>
        <a href="/Booking" class="mr-btn-ghost">See all specialists</a>
    </div>
}

@* ─── Trust Strip ─────────────────────────────────────────────── *@
<section class="mr-trust container-fluid">
    <div class="mr-trust__inner">
        <div class="mr-trust__item">
            <span class="mr-trust__num">2,400+</span>
            <span class="mr-trust__label">Sessions completed</span>
        </div>
        <div class="mr-trust__divider"></div>
        <div class="mr-trust__item">
            <span class="mr-trust__num">98%</span>
            <span class="mr-trust__label">Client satisfaction</span>
        </div>
        <div class="mr-trust__divider"></div>
        <div class="mr-trust__item">
            <span class="mr-trust__num">40+</span>
            <span class="mr-trust__label">Countries served</span>
        </div>
        <div class="mr-trust__divider"></div>
        <div class="mr-trust__item">
            <span class="mr-trust__num">72hr</span>
            <span class="mr-trust__label">Avg. first appointment</span>
        </div>
    </div>
</section>

@section Scripts {
<script src="~/js/booking.js" asp-append-version="true"></script>
}
