@model WebApplication1.Models.Professional
@{
    ViewData["Title"] = Model.Name + " — MindReply";
}

<div class="mrd-hero container-fluid">
    <div class="mrd-hero__inner">
        <div class="mrd-photo-wrap">
            <img src="@Model.PhotoUrl" alt="Photo of @Model.Name" class="mrd-photo"
                 onerror="this.src='https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=500&h=500&fit=crop&crop=face'" />
            @if (Model.IsAvailableToday)
            {
                <span class="mr-card__avail">Available today</span>
            }
        </div>
        <div class="mrd-info">
            @if (!string.IsNullOrEmpty(Model.Badge))
            {
                <div class="mr-card__badge mr-badge--@Model.Badge.ToLower().Replace(" ", "-") mrd-badge">@Model.Badge</div>
            }
            <p class="mr-card__role">@Model.Role</p>
            <h1 class="mrd-name">@Model.Name</h1>
            <p class="mr-card__niche">@Model.Niche</p>

            <div class="mr-card__stars mb-3" aria-label="Rating @Model.RatingStars out of 5">
                @for (int i = 1; i <= 5; i++)
                {
                    var full = (decimal)i <= Math.Floor(Model.RatingStars);
                    var half = !full && (decimal)i <= Model.RatingStars + 0.5m && Model.RatingStars % 1 >= 0.25m;
                    <span class="mr-star @(full ? "mr-star--full" : half ? "mr-star--half" : "mr-star--empty")">★</span>
                }
                <span class="mr-card__review-count">(@Model.ReviewCount reviews)</span>
            </div>

            <div class="mr-card__langs mb-2">
                @foreach (var lang in Model.Languages)
                {
                    <span class="mr-lang-tag">@lang</span>
                }
            </div>

            <div class="mr-card__tags mb-3">
                @foreach (var spec in Model.Specialties)
                {
                    <span class="mr-spec-tag">@spec</span>
                }
            </div>

            <p class="mrd-bio">@Model.ShortBio</p>

            <div class="mrd-price-row">
                <div>
                    <span class="mr-card__price" data-base-gbp="@Model.PriceGbp" data-symbol="£">£@Model.PriceGbp</span>
                    <span class="mr-card__session">/ @Model.SessionLength</span>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <a href="@Model.CalendarLink" class="mr-btn-book" target="_blank" rel="noopener noreferrer">Book Now</a>
                    <a href="/Booking/Group/@Model.Id" class="mr-btn-ghost">Group Booking</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mrd-body container">
    <div class="mrd-section">
        <h2>Location &amp; Format</h2>
        <p>@Model.Location — sessions available online worldwide.</p>
    </div>
    <div class="mrd-section">
        <h2>Book a session</h2>
        <p>Single session at £@Model.PriceGbp / @Model.SessionLength. Group discounts available for 10+ participants.</p>
        <div class="d-flex gap-3 flex-wrap">
            <a href="@Model.CalendarLink" class="mr-btn-book" target="_blank" rel="noopener noreferrer">Book Individual Session</a>
            <a href="/Booking/Group/@Model.Id" class="mr-btn-ghost">Organise Group Session</a>
        </div>
    </div>
    <div class="mrd-back">
        <a href="/Booking" class="mr-btn-ghost">← Back to all specialists</a>
    </div>
</div>
