{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mind-reply.com/playbooks/schema.json",
  "title": "MindReply Playbook",
  "description": "Strict schema for private decision playbooks. A playbook must reduce input to one required action and an auditable rationale.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "playbook_id",
    "title",
    "description",
    "version",
    "triggers",
    "decision_tree",
    "actions",
    "verification",
    "audit"
  ],
  "properties": {
    "playbook_id": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 8
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "pattern"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["email", "calendar", "file", "webhook", "manual"]
          },
          "pattern": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "decision_tree": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes"],
      "properties": {
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "condition", "action", "next"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "condition": {
                "type": "string",
                "minLength": 1
              },
              "action": {
                "type": "string",
                "enum": ["reply", "schedule", "resolve", "escalate"]
              },
              "next": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "template_id", "params"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["email_template", "api_call", "task_create", "calendar_event", "noop"]
          },
          "template_id": {
            "type": "string"
          },
          "params": {
            "type": "object"
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "roles"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exportable", "signed"],
      "properties": {
        "exportable": {
          "type": "boolean"
        },
        "signed": {
          "type": "boolean"
        }
      }
    }
  }
}
