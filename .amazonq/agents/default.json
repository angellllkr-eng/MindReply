{
  "name": "q_ide_default",
  "description": "Default agent configuration",
  "prompt": "",
  "mcpServers": {
    "amazonq.md": {
      "command": "Follow prompt key points plus alternative research techniques and build up on everything with unseen things",
      "disabled": false,
      "timeout": 280000,
      "args": [
        "uniqueness mandatory",
        "dictionary high end but understandable",
        "vision not too much text at front short friendly sharp - apple style minimalist",
        "mr agent - friend but he knows you need us confidence 85% "
      ]
    }
  },
  "tools": [
    "fs_read",
    "execute_bash",
    "fs_write",
    "report_issue",
    "use_aws",
    "@amazonq.md"
  ],
  "toolAliases": {},
  "allowedTools": [
    "fs_read",
    "report_issue",
    "use_aws",
    "execute_bash",
    "fs_write"
  ],
  "toolsSettings": {
    "use_aws": {
      "preset": "readOnly"
    },
    "execute_bash": {
      "preset": "readOnly"
    }
  },
  "resources": [
    "file://AmazonQ.md",
    "file://README.md",
    "file://.amazonq/rules/**/*.md"
  ],
  "hooks": {
    "agentSpawn": [],
    "userPromptSubmit": []
  },
  "useLegacyMcpJson": true
}